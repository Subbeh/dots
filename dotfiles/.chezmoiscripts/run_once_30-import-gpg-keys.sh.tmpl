#!/usr/bin/env bash
# Import GPG keys from Bitwarden

set -euo pipefail

{{- $gpgItemId := (bitwarden "item" "gpg-keys").id }}

echo "==> Importing GPG keys..."

export GPG_TTY="$(tty 2>/dev/null || true)"
gpgconf --launch gpg-agent

echo "===> Importing {{ .email }}.priv.asc..."
echo {{ bitwardenAttachment (printf "%s.priv.asc" .email) $gpgItemId | b64enc | quote }} | base64 -d | gpg --batch --no-tty --import 2>&1 \
  | grep -v "^gpg: key.*: already in secret keyring" || true

echo "===> Importing {{ .email }}.pub.asc..."
echo {{ bitwardenAttachment (printf "%s.pub.asc" .email) $gpgItemId | b64enc | quote }} | base64 -d | gpg --batch --no-tty --import 2>&1 \
  | grep -v "^gpg: key.*: already in secret keyring" || true

echo "===> Importing {{ .email }}.sub_priv.asc..."
echo {{ bitwardenAttachment (printf "%s.sub_priv.asc" .email) $gpgItemId | b64enc | quote }} | base64 -d | gpg --batch --no-tty --import 2>&1 \
  | grep -v "^gpg: key.*: already in secret keyring" || true

fpr=$(gpg --batch --no-tty --list-keys --with-colons {{ .email | quote }} \
  | awk -F: '/^fpr/{print $10; exit}')
echo "${fpr}:6:" | gpg --batch --no-tty --import-ownertrust

echo "==> GPG keys imported"
