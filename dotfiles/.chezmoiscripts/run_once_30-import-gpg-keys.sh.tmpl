#!/usr/bin/env bash
# Import GPG keys from Bitwarden

set -euo pipefail

SECRETS_FILE="{{ .chezmoi.sourceDir }}/.chezmoidata/secrets.json"

echo "==> Importing GPG keys..."

export GPG_TTY="$(tty 2>/dev/null || true)"
gpgconf --launch gpg-agent

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

jq -r '.gpg.priv_asc'      "$SECRETS_FILE" | base64 -d > "$tmpdir/priv.asc"
jq -r '.gpg.pub_asc'       "$SECRETS_FILE" | base64 -d > "$tmpdir/pub.asc"
jq -r '.gpg.sub_priv_asc'  "$SECRETS_FILE" | base64 -d > "$tmpdir/sub_priv.asc"

echo "===> Importing {{ .email }}.priv.asc..."
gpg --batch --no-tty --import "$tmpdir/priv.asc" 2>&1 \
  | grep -v "^gpg: key.*: already in secret keyring" || true

echo "===> Importing {{ .email }}.pub.asc..."
gpg --batch --no-tty --import "$tmpdir/pub.asc" 2>&1 \
  | grep -v "^gpg: key.*: already in secret keyring" || true

echo "===> Importing {{ .email }}.sub_priv.asc..."
gpg --batch --no-tty --import "$tmpdir/sub_priv.asc" 2>&1 \
  | grep -v "^gpg: key.*: already in secret keyring" || true

fpr=$(gpg --batch --no-tty --list-keys --with-colons {{ .email | quote }} \
  | awk -F: '/^fpr/{print $10; exit}')
echo "${fpr}:6:" | gpg --batch --no-tty --import-ownertrust

echo "==> GPG keys imported"
