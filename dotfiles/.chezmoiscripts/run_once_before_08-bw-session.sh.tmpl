#!/usr/bin/env bash
# Log in to Bitwarden and cache session token for subsequent scripts

set -euo pipefail

BW_SESSION_FILE="{{ .chezmoi.homeDir }}/.config/chezmoi/.bw-session"

if [[ -f "$BW_SESSION_FILE" ]]; then
  exit 0
fi

if ! command -v bw &>/dev/null; then
  echo "ERROR: bw (Bitwarden CLI) not found. Install it first." >&2
  exit 1
fi

echo "==> Logging in to Bitwarden..."

if bw login --check &>/dev/null; then
  BW_SESSION="$(bw unlock --raw)"
else
  BW_SESSION="$(bw login --raw)"
fi

mkdir -p "$(dirname "$BW_SESSION_FILE")"
echo "$BW_SESSION" > "$BW_SESSION_FILE"
chmod 600 "$BW_SESSION_FILE"

echo "==> Bitwarden session cached"
