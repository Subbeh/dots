#!/usr/bin/env bash
# Import SSH keys from Bitwarden

set -euo pipefail

SSH_DIR="{{ .chezmoi.homeDir }}/.ssh/keys"
SECRETS_FILE="{{ .chezmoi.sourceDir }}/.chezmoidata/secrets.json"

mkdir -p "$SSH_DIR"
chmod 700 "$(dirname "$SSH_DIR")" "$SSH_DIR"

echo "==> Importing SSH keys..."

{{ range .sshKeys -}}
echo "===> Importing {{ . }}..."
if [[ ! -f "$SSH_DIR/id_{{ . }}" ]]; then
  jq -r '.secrets.ssh["{{ . }}"].private' "$SECRETS_FILE" > "$SSH_DIR/id_{{ . }}"
  chmod 600 "$SSH_DIR/id_{{ . }}"
fi

if [[ ! -f "$SSH_DIR/id_{{ . }}.pub" ]]; then
  jq -r '.secrets.ssh["{{ . }}"].public' "$SECRETS_FILE" > "$SSH_DIR/id_{{ . }}.pub"
  chmod 644 "$SSH_DIR/id_{{ . }}.pub"
fi

{{ end -}}
echo "==> SSH keys imported"
