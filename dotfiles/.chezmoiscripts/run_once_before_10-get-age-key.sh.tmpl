#!/usr/bin/env bash
# Write age private key from Bitwarden to ~/.config/chezmoi/key.txt

set -euo pipefail

KEY_FILE="{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"
PUB_FILE="{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt.pub"
SECRETS_FILE="{{ .chezmoi.sourceDir }}/.chezmoidata/secrets.json"

if [[ -f "$KEY_FILE" && -f "$PUB_FILE" ]]; then
  exit 0
fi

echo "==> Writing age key..."

mkdir -p "$(dirname "$KEY_FILE")"

jq -r '.secrets.chezmoi["age-key"]'     "$SECRETS_FILE" > "$KEY_FILE"
jq -r '.secrets.chezmoi["age-key-pub"]' "$SECRETS_FILE" > "$PUB_FILE"
chmod 600 "$KEY_FILE"
chmod 644 "$PUB_FILE"

echo "==> Age key written to $(dirname "$KEY_FILE")"
