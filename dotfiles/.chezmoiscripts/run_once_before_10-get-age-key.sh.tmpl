#!/usr/bin/env bash
# Write age private key from Bitwarden to ~/.config/chezmoi/key.txt

set -euo pipefail

KEY_FILE="{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"

if [[ -f "$KEY_FILE" ]]; then
  exit 0
fi

echo "==> Writing age key..."

mkdir -p "$(dirname "$KEY_FILE")"

cat > "$KEY_FILE" << 'EOF'
{{ index (bitwardenFields "item" "chezmoi") "age-key" | dig "value" "" }}
EOF
chmod 600 "$KEY_FILE"

echo "==> Age key written to $(dirname "$KEY_FILE")"
