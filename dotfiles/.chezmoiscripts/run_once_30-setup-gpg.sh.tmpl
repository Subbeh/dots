#!/usr/bin/env bash
# Import GPG keys from Bitwarden attachments

set -euo pipefail

echo "==> Setting up GPG keys..."

BW_SESSION_FILE="{{ .chezmoi.homeDir }}/.config/chezmoi/.bw-session"
BW_SESSION="$(cat "$BW_SESSION_FILE")"
export BW_SESSION

item_id="$(bw list items --search gpg | jq -r '.[] | select(.name=="gpg") | .id')"

if [[ -z "$item_id" ]]; then
  echo "ERROR: Could not find 'gpg' item in Bitwarden" >&2
  exit 1
fi

# Ensure gpg-agent is running and reachable in this non-interactive context
export GPG_TTY="$(tty 2>/dev/null || true)"
gpgconf --launch gpg-agent

import_attachment() {
  local filename="$1"
  echo "==> Importing $filename..."
  bw get attachment "$filename" --itemid "$item_id" --raw \
    | gpg --batch --no-tty --import 2>&1 \
    | grep -v "^gpg: key.*: already in secret keyring" || true
}

import_attachment "{{ .email }}.priv.asc"
import_attachment "{{ .email }}.pub.asc"
import_attachment "{{ .email }}.sub_priv.asc"

# Set ultimate trust so gpg-agent doesn't prompt during encrypt
gpg --batch --no-tty --import-ownertrust <<EOF
$(gpg --batch --no-tty --list-keys --with-colons {{ .email | quote }} | awk -F: '$1=="fpr"{print $10":6:"}' | head -1)
EOF

echo "==> GPG keys imported"
